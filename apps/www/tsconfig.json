{
  "extends": "@site/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",  // Sets the base directory for module resolution
    "paths": {
      "@/*": ["src/*"],
      "contentlayer/generated": ["./.contentlayer/generated"]
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.js",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".contentlayer/generated"
  ]
}
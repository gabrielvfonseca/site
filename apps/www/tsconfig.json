{
  "extends": "@site/typescript-config/nextjs.json",
  "compilerOptions": { 
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./src/components/*"],
      "@styles/*": ["./src/styles/*"],
      "@utils/*": ["./src/utils/*"],
      "@content/*": ["./src/content/*"],
      "@emails/*": ["./src/email/emails/*"],
      "@services/*": ["./src/services/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@config*": ["./site.config.ts"],
      "@utils": ["./src/utils"],
      "@actions/*": ["./src/actions/*"],
      "@app/*": ["./src/app/*"],
      "@public": ["./public/*"],
      "@contentlayer": ["./.contentlayer/generated"],
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.js",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".contentlayer/generated", "../../utils/cn.ts", "../../ui/src/components/spinner.tsx",
  ],
  "exclude": ["node_modules"]
}

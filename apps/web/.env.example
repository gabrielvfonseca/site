# =============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION
# =============================================================================
# This file contains all environment variables needed for the codebase.
# Copy this file to .env.local and fill in your actual values.
# Never commit .env.local or any file containing real secrets to version control.

# =============================================================================
# CORE APPLICATION CONFIGURATION
# =============================================================================

# Web URL - Required for the application to work
NEXT_PUBLIC_WEB_URL="http://localhost:3000"

# Build Analysis (optional)
# Set to 'true' to enable bundle analysis
ANALYZE="false"

# Next.js Runtime (automatically set by Vercel)
NEXT_RUNTIME=""

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL - Required for database operations
# Format: postgresql://username:password@host:port/database
# Recommended for most uses
DATABASE_URL="your-database-url"

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Arcjet Security Key
# Format: ajkey_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARCJET_KEY="your-arcjet-key"

# =============================================================================
# RATE LIMITING & CACHING (Upstash Redis)
# =============================================================================

# Vercel KV REST API URL
# Format: https://your-kv-instance.upstash.io
UPSTASH_REDIS_REST_URL="your-kv-instance.upstash.io"

# Vercel KV REST API Token
# Format: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
UPSTASH_REDIS_REST_TOKEN="your-kv-token"

# =============================================================================
# ANALYTICS CONFIGURATION
# =============================================================================

# PostHog Analytics (optional)
# PostHog Project Key - Format: phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"

# PostHog Host URL
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com/"

# =============================================================================
# OBSERVABILITY & MONITORING
# =============================================================================

# Sentry Configuration (optional)
# Sentry Organization
SENTRY_ORG="your-sentry-org"

# Sentry Project
SENTRY_PROJECT="your-sentry-project"

# Sentry DSN (Data Source Name)
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Logtail Configuration (optional)
# Used for structured logging in production
LOGTAIL_SOURCE_TOKEN="your-logtail-token"

# =============================================================================
# DATA SOURCE INTEGRATIONS (Optional - power the /now and activity widgets)
# =============================================================================
# Each integration lives in its own @gabfon/* package and degrades gracefully:
# if a credential is missing, that widget simply shows "unavailable" instead of
# breaking the page. See each package's .env.example for details.

# GitHub (contribution graph, profile stats) - @gabfon/github
GITHUB_TOKEN="your-github-personal-access-token"
GITHUB_USERNAME="gabrielvfonseca"

# Spotify (now playing, top tracks) - @gabfon/spotify
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"
SPOTIFY_REFRESH_TOKEN="your-spotify-refresh-token"

# Strava (runs, activity totals; also Apple Watch runs once synced) - @gabfon/strava
STRAVA_CLIENT_ID="your-strava-client-id"
STRAVA_CLIENT_SECRET="your-strava-client-secret"
STRAVA_REFRESH_TOKEN="your-strava-refresh-token"

# WakaTime (coding hours) - @gabfon/wakatime
# From https://wakatime.com/settings/api-key
WAKATIME_API_KEY="your-wakatime-api-key"

# X / Twitter (latest post) - @gabfon/x
# Requires at least the paid Basic tier to read the timeline
X_API_BEARER_TOKEN="your-x-api-v2-bearer-token"
X_USERNAME="gabfon_"

# =============================================================================
# SOCIAL LINKS & CONTACT (Optional - has defaults)
# =============================================================================

# Social Media URLs (optional - will use defaults if not provided)
NEXT_PUBLIC_X_URL="https://x.com/gabfon_"
NEXT_PUBLIC_LINKEDIN_URL="https://www.linkedin.com/in/gabrielvfonseca/"
NEXT_PUBLIC_GITHUB_URL="https://github.com/gabrielvfonseca"
NEXT_PUBLIC_SCHEDULE_URL="https://calendar.notion.so/meet/gabfon/schedule"

NEXT_PUBLIC_EMAIL="hey@gabfon.com"

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================

# Node Environment (automatically set)
NODE_ENV="development"

# Optional secrets for the Docker Compose stack.
#
# Copy to `.env.docker` and fill in to enable the cloud integrations. All of
# these degrade gracefully when omitted, so the app still runs without them.
# DATABASE_URL / UPSTASH_REDIS_REST_* are wired automatically in docker-compose.yml
# (local Postgres + Redis proxies) and should NOT be set here.

# --- Email (Resend) — contact form + AMA notifications ---
# RESEND_TOKEN=re_xxxxxxxx
# RESEND_FROM=hey@example.com

# --- Bot protection (Arcjet) ---
# ARCJET_KEY=ajkey_xxxxxxxx

# --- Error tracking (Sentry) ---
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oXXXX.ingest.sentry.io/xxxx

# --- Product analytics (PostHog) ---
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Logging (Logtail / BetterStack) ---
# LOGTAIL_SOURCE_TOKEN=xxxxxxxx

# --- Activity graph integrations (optional) ---
# GITHUB_TOKEN=ghp_xxxxxxxx
# SPOTIFY_CLIENT_ID=xxxx
# SPOTIFY_CLIENT_SECRET=xxxx
# SPOTIFY_REFRESH_TOKEN=xxxx
# STRAVA_CLIENT_ID=xxxx
# STRAVA_CLIENT_SECRET=xxxx
# STRAVA_REFRESH_TOKEN=xxxx

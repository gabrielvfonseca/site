{
  "name": "@gabfon/observability",
  "version": "0.1.0",
  "description": "Sentry + Logtail observability integration for gabfon.com",
  "keywords": [
    "observability",
    "sentry",
    "logtail",
    "monitoring"
  ],
  "license": "MIT",
  "author": {
    "name": "Gabriel Fonseca",
    "email": "hey@gabfon.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gabriel-fonseca/site-main"
  },
  "bugs": {
    "url": "https://github.com/gabriel-fonseca/site-main/issues"
  },
  "homepage": "https://gabfon.com",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./keys": {
      "types": "./src/keys.ts",
      "import": "./src/keys.ts",
      "default": "./src/keys.ts"
    },
    "./next-config": {
      "types": "./src/next-config.ts",
      "import": "./src/next-config.ts",
      "default": "./src/next-config.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./log": {
      "types": "./src/log.ts",
      "import": "./src/log.ts",
      "default": "./src/log.ts"
    },
    "./instrumentation": {
      "types": "./src/instrumentation.ts",
      "import": "./src/instrumentation.ts",
      "default": "./src/instrumentation.ts"
    }
  },
  "scripts": {
    "build": "bunx tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest run",
    "test:unit": "vitest run unit",
    "test:integration": "vitest run integration",
    "test:e2e": "vitest run e2e",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "analyze": "echo 'No analysis specified'",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "bunx tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@logtail/next": "^0.2.1",
    "@sentry/nextjs": "^10.10.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "react": "19.2.1",
    "server-only": "^0.0.1",
    "zod": "^4.1.5"
  },
  "peerDependencies": {
    "next": "16.2.1"
  },
  "devDependencies": {
    "@gabfon/typescript-config": "workspace:*",
    "@gabfon/testing": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^27.0.0",
    "next": "16.2.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}

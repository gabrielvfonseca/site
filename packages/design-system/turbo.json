{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json",
        "!**/*.test.*",
        "!**/*.spec.*"
      ]
    },
    "test": {
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "test/**", "package.json", "*.config.*"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    }
  }
}

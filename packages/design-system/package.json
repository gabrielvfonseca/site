{
  "name": "@gabfon/design-system",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./src/index.tsx",
      "require": "./src/index.tsx"
    },
    "./styles/globals.css": "./globals.css",
    "./providers/*": {
      "import": "./src/providers/*.tsx",
      "require": "./src/providers/*.tsx"
    },
    "./lib/*": {
      "import": "./src/lib/*.ts",
      "require": "./src/lib/*.ts"
    },
    "./hooks/*": {
      "import": "./src/hooks/*.tsx",
      "require": "./src/hooks/*.tsx"
    },
    "./components/*": {
      "import": "./src/components/*.tsx",
      "require": "./src/components/*.tsx"
    },
    "./postcss.config.mjs": {
      "import": "./postcss.config.mjs",
      "require": "./postcss.config.mjs"
    }
  },
  "scripts": {
    "build": "tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest run",
    "test:unit": "vitest run unit",
    "test:integration": "vitest run integration",
    "test:e2e": "vitest run e2e",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "analyze": "echo 'No analysis specified'",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@gabfon/analytics": "workspace:*",
    "@gabfon/observability": "workspace:*",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.5.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.542.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.1",
    "react-day-picker": "^9.9.0",
    "react-hook-form": "^7.77.0",
    "react-moveable": "^0.56.0",
    "react-resizable-panels": "^3.0.5",
    "recharts": "^3.1.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.8",
    "vaul": "^1.1.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@gabfon/typescript-config": "workspace:*",
    "@gabfon/testing": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^24.3.1",
    "@types/react": "19.2.7",
    "@vitejs/plugin-react": "^5.0.2",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}

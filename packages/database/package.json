{
  "name": "@gabfon/database",
  "version": "0.1.0",
  "description": "Neon / PostgreSQL database client and schema for gabfon.com",
  "keywords": [
    "database",
    "postgresql",
    "neon",
    "drizzle-orm"
  ],
  "license": "MIT",
  "author": {
    "name": "Gabriel Fonseca",
    "email": "hey@gabfon.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gabriel-fonseca/site-main"
  },
  "bugs": {
    "url": "https://github.com/gabriel-fonseca/site-main/issues"
  },
  "homepage": "https://gabfon.com",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./keys": {
      "types": "./src/keys.ts",
      "import": "./src/keys.ts",
      "default": "./src/keys.ts"
    }
  },
  "scripts": {
    "build": "bunx tsc --noEmit --emitDeclarationOnly false",
    "test": "echo 'No tests specified'",
    "test:watch": "echo 'No tests specified'",
    "test:coverage": "echo 'No tests specified'",
    "analyze": "echo 'No analysis specified'",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "bunx tsc --noEmit --emitDeclarationOnly false",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@gabfon/typescript-config": "workspace:*",
    "@types/node": "24.10.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}

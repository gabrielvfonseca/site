{
  "name": "@gabfon/database",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts",
      "default": "./src/schema.ts"
    },
    "./keys": {
      "types": "./src/keys.ts",
      "import": "./src/keys.ts",
      "default": "./src/keys.ts"
    }
  },
  "scripts": {
    "build": "bunx tsc --noEmit --emitDeclarationOnly false",
    "test": "echo 'No tests specified'",
    "analyze": "echo 'No analysis specified'",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "bunx tsc --noEmit --emitDeclarationOnly false",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@t3-oss/env-nextjs": "^0.13.8",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@gabfon/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.2"
  }
}

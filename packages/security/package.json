{
  "name": "@gabfon/security",
  "version": "0.1.0",
  "description": "Arcjet + Nosecone security middleware for gabfon.com",
  "keywords": [
    "security",
    "arcjet",
    "nosecone",
    "middleware"
  ],
  "license": "MIT",
  "author": {
    "name": "Gabriel Fonseca",
    "email": "hey@gabfon.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gabriel-fonseca/site-main"
  },
  "bugs": {
    "url": "https://github.com/gabriel-fonseca/site-main/issues"
  },
  "homepage": "https://gabfon.com",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./keys": {
      "types": "./src/keys.ts",
      "import": "./src/keys.ts",
      "default": "./src/keys.ts"
    },
    "./proxy": {
      "types": "./src/proxy.ts",
      "import": "./src/proxy.ts",
      "default": "./src/proxy.ts"
    }
  },
  "scripts": {
    "build": "bunx tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest run",
    "test:unit": "vitest run unit",
    "test:integration": "vitest run integration",
    "test:e2e": "vitest run e2e",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "analyze": "echo 'No analysis specified'",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "bunx tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@arcjet/next": "1.0.0-beta.11",
    "@nosecone/next": "1.0.0-beta.11",
    "@t3-oss/env-nextjs": "^0.13.8",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@gabfon/testing": "workspace:*",
    "@gabfon/typescript-config": "workspace:*",
    "@types/node": "24.10.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
